{
  "name": "@explorers-map/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "env EXPLORERS_MAP_WORKSPACE_ROOT=../.. node ./scripts/run-next.mjs dev --webpack",
    "build": "env EXPLORERS_MAP_WORKSPACE_ROOT=../.. node ./scripts/run-next.mjs build --webpack",
    "start": "env EXPLORERS_MAP_WORKSPACE_ROOT=../.. node ./scripts/run-next.mjs start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test ./*.test.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@explorers-map/db": "workspace:*",
    "@explorers-map/services": "workspace:*",
    "@explorers-map/utils": "workspace:*",
    "better-auth": "^1.5.6",
    "better-sqlite3": "^12.8.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
