    "/api/actions/v1/countries/{countrySlug}/regions/{regionSlug}/listings": {
      "get": {
        "operationId": "listListingsForRegion",
        "tags": [
          "Listings"
        ],
        "summary": "List listings in a region",
        "description": "List editorial-visible listings in a region. Drafts are included and trashed listings are excluded.",
        "parameters": [
          {
            "name": "countrySlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "regionSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Listings returned.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "listings": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ListingRecord"
                      }
                    }
                  },
                  "required": [
                    "listings"
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "post": {
        "operationId": "ensureListingDraft",
        "tags": [
          "Listings"
        ],
        "summary": "Ensure a listing draft exists",
        "description": "Search for a safe existing listing match before creating a new draft in the target region. Reuse exact matches, but treat fuzzy listing candidates as advisory context rather than automatic hard stops. When the user asks you to add a place, gather credible evidence yourself when possible, then create only with complete evidence-backed fields.",
        "x-openai-isConsequential": true,
        "parameters": [
          {
            "name": "countrySlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "regionSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateListingBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Listing matched, or a new draft was created with any advisory candidates and warnings.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnsureListingResult"
                }
              }
            }
          },
          "201": {
            "description": "Listing draft created, potentially with advisory candidates or warnings.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnsureListingResult"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidInput"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "422": {
            "$ref": "#/components/responses/InsufficientEvidence"
          }
        }
      }
    },
