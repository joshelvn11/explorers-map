{
  "openapi": "3.1.0",
  "info": {
    "title": "Explorers Map Actions API",
    "version": "1.0.0",
    "description": "Authenticated HTTP API for ChatGPT Actions to inspect existing Explorers Map editorial content and create duplicate-safe draft records. When Web Search is available, the GPT should gather credible evidence itself before calling create endpoints."
  },
  "servers": [
    {
      "url": "https://explorersmap.org"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Reference"
    },
    {
      "name": "Regions"
    },
    {
      "name": "Destinations"
    },
    {
      "name": "Listings"
    }
  ],
  "paths": {
    "/api/actions/v1/countries": {
      "get": {
        "operationId": "listCountries",
        "tags": [
          "Reference"
        ],
        "summary": "List countries",
        "description": "List all countries currently available in Explorers Map.",
        "responses": {
          "200": {
            "description": "Countries returned.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "countries": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/CountryRecord"
                      }
                    }
                  },
                  "required": [
                    "countries"
                  ]
                },
                "example": {
                  "countries": [
                    {
                      "slug": "united-kingdom",
                      "title": "United Kingdom",
                      "description": "Explore curated regions and destinations across the UK.",
                      "coverImage": "https://picsum.photos/seed/united-kingdom/1600/900"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      }
    },
    "/api/actions/v1/countries/{countrySlug}": {
      "get": {
        "operationId": "getCountry",
        "tags": [
          "Reference"
        ],
        "summary": "Get a country",
        "description": "Fetch one country by slug.",
        "parameters": [
          {
            "name": "countrySlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Country returned.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "country": {
                      "$ref": "#/components/schemas/CountryRecord"
                    }
                  },
                  "required": [
                    "country"
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/actions/v1/categories": {
      "get": {
        "operationId": "listCategories",
        "tags": [
          "Reference"
        ],
        "summary": "List categories",
        "description": "List the fixed curated categories that can be used for listings.",
        "responses": {
          "200": {
            "description": "Categories returned.",
