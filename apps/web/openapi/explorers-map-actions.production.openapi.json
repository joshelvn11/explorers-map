          {
            "name": "regionSlug",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Optional region slug to prefer destinations already linked to that region."
          }
        ],
        "responses": {
          "200": {
            "description": "Search result returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FindResult"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidInput"
