          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      }
    },
    "/api/actions/v1/countries/{countrySlug}/regions": {
      "get": {
        "operationId": "listRegions",
        "tags": [
          "Regions"
        ],
        "summary": "List regions",
        "description": "List all regions in a country.",
        "parameters": [
          {
            "name": "countrySlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Regions returned.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "regions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/RegionRecord"
                      }
                    }
                  },
                  "required": [
                    "regions"
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "post": {
        "operationId": "ensureRegion",
        "tags": [
          "Regions"
        ],
        "summary": "Ensure a region exists",
        "description": "Check for a safe existing region match first. If no safe match exists, gather credible evidence yourself when possible and create a new region only with evidence-backed fields. Ask the user for help only when the target is ambiguous or credible evidence cannot be found.",
        "x-openai-isConsequential": true,
        "parameters": [
          {
            "name": "countrySlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRegionBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Region matched or creation stopped safely.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnsureRegionResult"
                }
              }
            }
          },
          "201": {
            "description": "Region created.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnsureRegionResult"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidInput"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "422": {
            "$ref": "#/components/responses/InsufficientEvidence"
          }
        }
      }
    },
    "/api/actions/v1/countries/{countrySlug}/regions/search": {
      "get": {
        "operationId": "findRegion",
        "tags": [
          "Regions"
        ],
        "summary": "Search regions",
        "description": "Search regions by title or slug and return exact, candidate, or not-found results.",
        "parameters": [
          {
            "name": "countrySlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
