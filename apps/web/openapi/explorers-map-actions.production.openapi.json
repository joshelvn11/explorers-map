    "/api/actions/v1/countries/{countrySlug}/destinations/search": {
      "get": {
        "operationId": "findDestination",
        "tags": [
          "Destinations"
        ],
        "summary": "Search destinations",
        "description": "Search destinations by title or slug, optionally boosting results linked to a specific region.",
        "parameters": [
          {
            "name": "countrySlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
