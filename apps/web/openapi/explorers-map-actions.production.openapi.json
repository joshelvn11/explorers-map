        "x-openai-isConsequential": true,
        "parameters": [
          {
            "name": "countrySlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDestinationBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Destination matched or creation stopped safely.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnsureDestinationResult"
                }
              }
            }
          },
          "201": {
            "description": "Destination created.",
