{
  "name": "explorers-map",
  "private": true,
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "dev:web": "pnpm --filter @explorers-map/web dev",
    "dev:mcp": "pnpm --filter @explorers-map/mcp dev",
    "build:web": "pnpm --filter @explorers-map/web build",
    "lint:web": "pnpm --filter @explorers-map/web lint",
    "typecheck:web": "pnpm --filter @explorers-map/web typecheck",
    "test:web": "pnpm --filter @explorers-map/web test",
    "typecheck:mcp": "pnpm --filter @explorers-map/mcp typecheck",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test:services": "pnpm --filter @explorers-map/services test",
    "test:mcp": "pnpm --filter @explorers-map/mcp test",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "studio": "drizzle-kit studio --config=drizzle.config.ts",
    "seed": "node --experimental-strip-types scripts/seed.ts import",
    "seed:validate": "node --experimental-strip-types scripts/seed.ts validate",
    "seed:smoke": "node --experimental-strip-types scripts/seed-smoke.ts"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  }
}
