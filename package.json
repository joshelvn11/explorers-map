{
  "name": "explorers-map",
  "private": true,
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "dev:web": "pnpm --filter @explorers-map/web dev",
    "build:web": "pnpm --filter @explorers-map/web build",
    "lint:web": "pnpm --filter @explorers-map/web lint",
    "typecheck:web": "pnpm --filter @explorers-map/web typecheck",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "seed": "node scripts/seed.mjs",
    "seed:validate": "node scripts/seed.mjs"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  }
}
